# Copy to .env and fill in real values. Do NOT commit .env.

# PostgreSQL credentials (used by both the postgres and app services).
POSTGRES_USER=finrag
POSTGRES_PASSWORD=change-me
POSTGRES_DB=finrag

# API keys — required by the app service.
VOYAGE_API_KEY=pa-your-voyage-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# HTTP port the API listens on.
PORT=8080
